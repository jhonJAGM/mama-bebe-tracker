# ══════════════════════════════════════════════════════════
#  mama-bebe-tracker — Variables de entorno
#  Copia este archivo a .env.local y completa los valores.
#  NUNCA commitees .env.local con valores reales.
# ══════════════════════════════════════════════════════════

# ── MongoDB Atlas ──────────────────────────────────────────
# Obtén la URI en: Atlas → tu cluster → Connect → Drivers
# Formato: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DB_NAME?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/mama-bebe-tracker?retryWrites=true&w=majority

# ── NextAuth.js v5 ─────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET=genera-un-secreto-aleatorio-de-32-chars
# NEXTAUTH_SECRET es el mismo que AUTH_SECRET (alias para compatibilidad)
NEXTAUTH_SECRET=genera-un-secreto-aleatorio-de-32-chars

# URL pública de tu app (sin trailing slash)
# En desarrollo: http://localhost:3000
# En Railway: https://tu-app.railway.app
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth (para login y Google Calendar) ────────────
# Crear en: console.cloud.google.com → APIs → Credenciales → OAuth 2.0
# Scopes requeridos: openid, email, profile, https://www.googleapis.com/auth/calendar
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google  (desarrollo)
#   - https://tu-app.railway.app/api/auth/callback/google  (producción)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Calendar API ────────────────────────────────────
# Habilitar en: console.cloud.google.com → APIs → Google Calendar API
# API Key (para lectura pública de calendarios):
GOOGLE_CALENDAR_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Calendar ID de la cuenta (lo ves en Configuración del calendario):
GOOGLE_CALENDAR_ID=primary

# ── Evolution API (WhatsApp bot) ───────────────────────────
# URL base de tu instancia de Evolution API
EVOLUTION_API_URL=https://tu-evolution-api.com
# API Key de tu instancia
EVOLUTION_API_KEY=tu-api-key-de-evolution
# Nombre de la instancia creada en Evolution API
EVOLUTION_INSTANCE=mama-bebe-bot
# Número de WhatsApp que recibirá las alertas (con código de país, sin +)
WHATSAPP_ALERT_PHONE=5491100000000

# ── Firebase (push notifications) ─────────────────────────
# Crear proyecto en: console.firebase.google.com
# Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=tu-proyecto-firebase
# La clave privada tiene saltos de línea — ponla entre comillas y usa \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxxxx\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# VAPID key para push web (Firebase → Project Settings → Cloud Messaging)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Autenticación familiar ─────────────────────────────────
# Credenciales de acceso (usuario y contraseña para la familia)
APP_USERNAME=familiaGM
APP_PASSWORD=NOAH2026

# ── WhatsApp grupo "Alertas Noe" ──────────────────────────
# JID del grupo de WhatsApp (cópialo de Evolution API → Grupos)
# Formato: 120363XXXXXXXXXX@g.us
WHATSAPP_GROUP_JID=120363XXXXXXXXXX@g.us
# Teléfono alternativo si no usas grupo (con código de país, sin +)
WHATSAPP_ALERT_PHONE=5731XXXXXXXX

# ── Webhook WhatsApp ───────────────────────────────────────
# Secreto para validar que los webhooks vienen de Evolution API
# Configúralo también en Evolution API → Webhook → Headers: x-webhook-secret
WEBHOOK_SECRET=genera-un-secreto-seguro-aqui

# ── Opcionales ─────────────────────────────────────────────
# Activa el Service Worker en desarrollo (por defecto solo en producción)
NEXT_PUBLIC_SW_DEV=false
